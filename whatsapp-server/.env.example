# WhatsApp Gateway Server Configuration

# Server Port
PORT=3000

# Server Host (localhost for local, 0.0.0.0 for external access)
HOST=localhost

# Laravel API URL (untuk callback jika diperlukan)
LARAVEL_API_URL=http://localhost:8000

# Session Name (nama folder untuk menyimpan session WhatsApp)
SESSION_NAME=spmb-wa-session

# Log Level (trace, debug, info, warn, error, fatal)
LOG_LEVEL=info

# Auto Reconnect (true/false)
AUTO_RECONNECT=true

# Max Reconnect Attempts
MAX_RECONNECT_ATTEMPTS=5

# Reconnect Interval (in milliseconds)
RECONNECT_INTERVAL=5000
