# Nama Aplikasi
APP_NAME="PPDB Online SIPDB"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

# Locale (Bahasa)
APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

# Database Configuration
# Gunakan SQLite (paling mudah untuk development)
DB_CONNECTION=sqlite

# Atau MySQL (jika ingin menggunakan MySQL)
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=ppdb_sipdb
# DB_USERNAME=root
# DB_PASSWORD=100%Muttaqin

# Konfigurasi Session
SESSION_DRIVER=database
SESSION_LIFETIME=120

# Konfigurasi Mail (untuk notifikasi email)
MAIL_MAILER=log
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.mailtrap.io
# MAIL_PORT=465
# MAIL_USERNAME=your_email@example.com
# MAIL_PASSWORD=your_password
# MAIL_FROM_ADDRESS="noreply@ppdb.com"
# MAIL_FROM_NAME="${APP_NAME}"

# Queue Configuration
QUEUE_CONNECTION=database

# Cache Configuration
CACHE_STORE=database

# Konfigurasi Vite
VITE_APP_NAME="${APP_NAME}"

# Admin Seeder
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@spmb.local
ADMIN_PASSWORD=change-this-password
ADMIN_NAME="Administrator Sistem"

PANITIA_USERNAME=panitia1
PANITIA_EMAIL=panitia@spmb.local
PANITIA_PASSWORD=change-this-password
PANITIA_NAME="Panitia Pendaftaran"

ADMIN_WA_EMAIL=adminwa@spmb.local
ADMIN_WA_PASSWORD=change-this-password
ADMIN_WA_NAME="Admin WhatsApp"

# Telegram Configuration (for WhatsApp Gateway alerts)
# Get bot token from @BotFather in Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Get chat_id from your group chat (can use @getidsbot)
TELEGRAM_CHAT_ID=your_chat_id_here
