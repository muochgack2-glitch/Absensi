# WhatsApp Gateway Server Configuration - BACKUP GATEWAY for SPMB

# Server Port (MUST BE DIFFERENT FROM PRIMARY - Port 3001 for backup)
PORT=3001

# Server Host (0.0.0.0 for external access)
HOST=0.0.0.0

# Laravel API URL (untuk callback jika diperlukan)
LARAVEL_API_URL=http://localhost:8000

# Session Name (MUST BE DIFFERENT FROM PRIMARY)
SESSION_NAME=spmb-wa-session-backup

# Log Level (trace, debug, info, warn, error, fatal)
LOG_LEVEL=info

# Auto Reconnect (true/false)
AUTO_RECONNECT=true

# Max Reconnect Attempts
MAX_RECONNECT_ATTEMPTS=5

# Reconnect Interval (in milliseconds)
RECONNECT_INTERVAL=5000
